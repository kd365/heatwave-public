# ============================================================
# HEATWAVE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is committed.
# ============================================================

# ---------------------------
# AWS
# ---------------------------
AWS_REGION=us-east-1
# AWS_PROFILE=default   # uncomment if not using env creds

# ---------------------------
# Bedrock
# ---------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=          # set after terraform apply
BEDROCK_GUARDRAIL_ID=               # set after terraform apply
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ---------------------------
# S3 Buckets (set after terraform apply)
# ---------------------------
S3_RAW_DATA_BUCKET=heatwave-raw-data-dev
S3_PROCESSED_BUCKET=heatwave-processed-dev
S3_RAG_DOCS_BUCKET=heatwave-rag-docs-dev
S3_FRONTEND_BUCKET=heatwave-frontend-dev

# ---------------------------
# DynamoDB
# ---------------------------
DYNAMODB_TABLE_NAME=heatwave-pipeline-runs-dev

# ---------------------------
# Lambda / API Gateway
# ---------------------------
LAMBDA_FUNCTION_NAME=heatwave-backend-dev
API_GATEWAY_URL=                    # set after terraform apply, e.g. https://xxxx.execute-api.us-east-1.amazonaws.com

# ---------------------------
# CloudWatch
# ---------------------------
CLOUDWATCH_NAMESPACE=HEATWAVE
CLOUDWATCH_DASHBOARD_NAME=HEATWAVE-Observability

# ---------------------------
# Frontend (Vite — must be prefixed with VITE_)
# ---------------------------
VITE_API_BASE_URL=                  # same as API_GATEWAY_URL, used by React app

# ---------------------------
# App Config
# ---------------------------
LOG_LEVEL=INFO
ENVIRONMENT=dev
