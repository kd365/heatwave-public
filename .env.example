# ============================================================
# HEATWAVE — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is committed.
# ============================================================

# ---------------------------
# AWS
# ---------------------------
AWS_REGION=us-east-1
# AWS_PROFILE=default   # uncomment if not using env creds

# ---------------------------
# Bedrock
# ---------------------------
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=          # from: terraform output knowledge_base_id
BEDROCK_GUARDRAIL_ID=               # set after terraform apply (Phase 9)
BEDROCK_GUARDRAIL_VERSION=DRAFT

# ---------------------------
# S3 — single bucket, multiple prefixes
# raw/        → operational data (911, 311, weather, social media)
# rag/        → reference docs for KB ingestion
# results/    → agent pipeline outputs
# ---------------------------
DATA_BUCKET=                        # from: terraform output data_bucket_name

# ---------------------------
# DynamoDB
# ---------------------------
DYNAMODB_TABLE_NAME=                # from: terraform output pipeline_runs_table_name

# ---------------------------
# Lambda / API Gateway
# ---------------------------
LAMBDA_FUNCTION_NAME=               # from: terraform output lambda_function_name
API_GATEWAY_URL=                    # from: terraform output api_gateway_url

# ---------------------------
# CloudWatch
# ---------------------------
CLOUDWATCH_NAMESPACE=HEATWAVE
CLOUDWATCH_DASHBOARD_NAME=HEATWAVE-Observability

# ---------------------------
# Frontend (Vite — must be prefixed with VITE_)
# ---------------------------
VITE_API_BASE_URL=                  # same as API_GATEWAY_URL, used by React app

# ---------------------------
# App Config
# ---------------------------
LOG_LEVEL=INFO
ENVIRONMENT=dev
