!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---------------------------
# OS
# ---------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V8
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------
# Logs & Runtime
# ---------------------------
*.log
logs/
*.pid
*.seed
*.pid.lock

# ---------------------------
# Data (keep curated datasets, ignore very large files)
# ---------------------------
data/raw/*.csv
data/raw/*.parquet
# Keep JSON datasets (911, weather) — curated for the project
# Keep reference PDFs (they are the RAG corpus)
# Keep synthetic datasets

# ---------------------------
